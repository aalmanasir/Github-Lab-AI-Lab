# ClowdBot Configuration
# Copy this to .env and fill in your values

# Discord Bot
DISCORD_TOKEN=               # Your Discord bot token
DISCORD_COMMAND_PREFIX=!     # Command prefix (default: !)

# GitHub Integration
GITHUB_WEBHOOK_SECRET=       # Secret for verifying GitHub webhooks
GITHUB_TOKEN=                # GitHub API token (for API calls)

# OpenAI (optional)
OPENAI_API_KEY=              # OpenAI API key

# Database
DATABASE_URL=sqlite:///data/clowdbot.db  # SQLite database path

# API Server
API_HOST=0.0.0.0            # API bind host
API_PORT=8080               # API bind port

# Application
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR, CRITICAL
ENVIRONMENT=development     # development, staging, production
APP_VERSION=0.1.0           # Application version string

# Discord Channels (comma-separated channel IDs)
ALLOWED_CHANNELS=           # e.g., 123456789,987654321

# Alerting
ALERT_WEBHOOK_URL=          # Discord/Slack webhook URL for alerts
